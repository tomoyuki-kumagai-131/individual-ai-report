# ---- Supabase ----
# Project settings > API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# ---- Database (Drizzle) ----
# Project settings > Database > Connection string.
# Use the "Session"/direct connection for migrations (drizzle-kit) and the
# pooled "Transaction" connection (port 6543) for the running app if you like.
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres"

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY="sk-ant-..."
# Optional override. Defaults to claude-sonnet-5 (see src/lib/ai/anthropic.ts).
ANTHROPIC_MODEL="claude-sonnet-5"

# ---- App ----
# Base URL used for OAuth redirects. Set to your deployed URL in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Analysis "day" is bucketed in this timezone.
APP_TIMEZONE="Asia/Tokyo"
# Shared secret to protect the cron endpoint. Vercel Cron sends it as a
# Bearer token via the CRON_SECRET env var automatically.
CRON_SECRET="generate-a-long-random-string"
